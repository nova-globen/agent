@page "/targets"
@inject AgentSyncApp App

<PageTitle>Agent Sync — Targets</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentLabel Typo="Typography.H3">Targets</FluentLabel>

    @* ---- Add target (explicit submit; writes agent.yaml) ---- *@
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
            <FluentLabel Typo="Typography.H4">Add a target</FluentLabel>
            <FluentTextField @bind-Value="_vm.AddId" Label="Target id" Placeholder="gemini" />
            <FluentTextField @bind-Value="_vm.AddPath" Label="Path (optional; default per adapter)" Placeholder=".gemini/GEMINI.md" />
            <FluentCheckbox @bind-Value="_vm.AddEnabled" Label="Enabled" />
            <FluentLabel Typo="Typography.Body">
                Known ids: @string.Join(", ", TargetIds.Ordered). Paths must stay inside the repository.
            </FluentLabel>
            <div>
                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _vm.Add())" Disabled="@string.IsNullOrWhiteSpace(_vm.AddId)">Add target</FluentButton>
            </div>
            <AuthoringResultView Result="_vm.AddResult" />
        </FluentStack>
    </FluentCard>

    @* ---- Known targets ---- *@
    @foreach (var target in _vm.Targets)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                <FluentLabel>
                    <strong>@target.Id</strong> —
                    @(!target.Configured ? "not configured" : target.Enabled ? $"enabled → {target.Path}" : "disabled")
                </FluentLabel>

                @if (target.Configured)
                {
                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                        <FluentButton OnClick="@(() => _vm.BeginEdit(target))">Edit…</FluentButton>
                        <FluentButton OnClick="@(() => _vm.RequestDelete(target.Id))">Delete…</FluentButton>
                    </FluentStack>
                }

                @* ---- Edit (explicit Save) ---- *@
                @if (_vm.EditId == target.Id)
                {
                    <FluentCard Style="margin-top: 8px;">
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                            <FluentLabel Typo="Typography.H4">Edit @target.Id</FluentLabel>
                            <FluentTextField @bind-Value="_vm.EditPath" Label="Path" />
                            <FluentCheckbox @bind-Value="_vm.EditEnabled" Label="Enabled" />
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _vm.SaveEdit())">Save changes</FluentButton>
                                <FluentButton OnClick="@(() => _vm.CancelEdit())">Cancel</FluentButton>
                            </FluentStack>
                            <AuthoringResultView Result="_vm.EditResult" />
                        </FluentStack>
                    </FluentCard>
                }

                @* ---- Delete confirmation (second step before any write) ---- *@
                @if (_vm.PendingDeleteId == target.Id)
                {
                    <FluentCard Style="margin-top: 8px;">
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                            <FluentLabel Typo="Typography.H4">Delete target @target.Id?</FluentLabel>
                            <FluentLabel>
                                This removes the target from <code>.agent/agent.yaml</code>. Any files already
                                projected for this target stay on disk and its lockfile entries become orphaned
                                until pruned. Use <strong>Force</strong> to delete even if projections exist
                                (also prunes the target's lockfile entries).
                            </FluentLabel>
                            <FluentCheckbox @bind-Value="_vm.DeleteDryRun" Label="Dry run (preview only — nothing written)" />
                            <FluentCheckbox @bind-Value="_vm.DeleteForce" Label="Force (delete even if projected; prune lockfile)" />
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _vm.ConfirmDelete())">Confirm delete</FluentButton>
                                <FluentButton OnClick="@(() => _vm.CancelDelete())">Cancel</FluentButton>
                            </FluentStack>
                            <AuthoringResultView Result="_vm.DeleteResult" />
                        </FluentStack>
                    </FluentCard>
                }
            </FluentStack>
        </FluentCard>
    }
</FluentStack>

@code {
    private TargetsViewModel _vm = default!;

    // Repository logic lives in TargetsViewModel / AgentSyncApp, never in this component.
    protected override void OnInitialized() => _vm = new TargetsViewModel(App);
}
