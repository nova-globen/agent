@page "/"
@inject AgentSyncApp App
@inject NavigationManager Nav

<PageTitle>Agent Sync — Dashboard</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentLabel Typo="Typography.H3">Dashboard</FluentLabel>

    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
            <FluentLabel><strong>Repository:</strong> @_state?.RepoPath</FluentLabel>
            <FluentLabel><strong>Git repository:</strong> @(_state?.IsGitRepository == true ? "yes" : "no")</FluentLabel>
            <FluentLabel><strong>Initialized:</strong> @(_state?.Initialized == true ? "yes" : "no")</FluentLabel>
            <FluentLabel><strong>Skills:</strong> @(_state?.SkillCount)</FluentLabel>
            <FluentLabel><strong>Drift / problems:</strong> @(_state?.HasProblems == true ? "yes" : "no")</FluentLabel>
        </FluentStack>
    </FluentCard>

    <FluentLabel Typo="Typography.H4">Quick actions</FluentLabel>
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true">
        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Nav.NavigateTo("/status"))">Status / Sync</FluentButton>
        <FluentButton OnClick="@(() => Nav.NavigateTo("/status"))">Validate</FluentButton>
        <FluentButton OnClick="@(() => Nav.NavigateTo("/imports"))">Import skill</FluentButton>
        <FluentButton OnClick="@(() => Nav.NavigateTo("/skills"))">Add skill</FluentButton>
        <FluentButton OnClick="@(() => Nav.NavigateTo("/diff"))">Diff</FluentButton>
    </FluentStack>

    <FluentLabel>CI command: <code>@AgentSyncApp.CiCommand</code></FluentLabel>
</FluentStack>

@code {
    private RepositoryState? _state;

    // Read-only view of state; mutations happen only on their own screens, after an
    // explicit confirmation that calls the application service.
    protected override void OnInitialized() => _state = App.GetState();
}
