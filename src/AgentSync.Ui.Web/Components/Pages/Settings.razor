@page "/settings"
@inject AgentSyncApp App

<PageTitle>Agent Sync — Settings</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
    <FluentLabel Typo="Typography.H3">Settings / Logs</FluentLabel>
    <FluentLabel><strong>Active repository:</strong> @App.RepoRoot</FluentLabel>
    <FluentLabel Typo="Typography.Body">
        This session is scoped to a single repository, served on 127.0.0.1 with a
        short-lived session token. Logs and policy settings are placeholders.
    </FluentLabel>
</FluentStack>
