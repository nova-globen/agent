@page "/hooks"
@inject AgentSyncApp App

<PageTitle>Agent Sync — Hooks / CI</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentLabel Typo="Typography.H3">Hooks / CI</FluentLabel>

    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
            <FluentLabel>Copy this into your pipeline:</FluentLabel>
            <pre style="margin: 0;">@AgentSyncApp.CiCommand</pre>
            <FluentLabel Typo="Typography.Body">It exits non-zero if drift or invalid state exists.</FluentLabel>
        </FluentStack>
    </FluentCard>

    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
            <FluentLabel Typo="Typography.H4">Git hooks</FluentLabel>
            <FluentLabel Typo="Typography.Body">
                Installing hooks sets <code>core.hooksPath</code> to <code>.githooks</code> and writes the
                pre-commit / pre-push hooks (making them executable on Unix). This modifies your Git
                config and working tree — confirm before running. The CLI equivalent is
                <code>agent install-hooks</code>.
            </FluentLabel>
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _vm.RequestInstall())">Install hooks…</FluentButton>
            </FluentStack>

            @if (_vm.InstallPending)
            {
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                        <FluentLabel>Set core.hooksPath and write the hook scripts now?</FluentLabel>
                        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _vm.ConfirmInstall())">Confirm install</FluentButton>
                            <FluentButton OnClick="@(() => _vm.CancelInstall())">Cancel</FluentButton>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            }

            @if (_vm.Result is not null)
            {
                <FluentCard Style="margin-top: 8px;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                        <FluentLabel><strong>@(_vm.Result.Success ? "Hooks installed." : "Hooks not fully installed.")</strong></FluentLabel>
                        <FluentLabel>core.hooksPath: <code>@_vm.Result.HooksPath</code> (@(_vm.Result.GitConfigured ? "configured" : "not configured"))</FluentLabel>
                        @foreach (var hook in _vm.Result.Hooks)
                        {
                            <FluentLabel><code>@hook.Name</code> — @(!hook.Present ? "missing" : hook.Executable ? "ready" : "not executable")</FluentLabel>
                        }
                        @if (!string.IsNullOrWhiteSpace(_vm.Result.Error))
                        {
                            <FluentLabel>@_vm.Result.Error</FluentLabel>
                        }
                    </FluentStack>
                </FluentCard>
            }
        </FluentStack>
    </FluentCard>
</FluentStack>

@code {
    private HooksViewModel _vm = default!;

    // Repository logic lives in HooksViewModel / AgentSyncApp, never in this component.
    protected override void OnInitialized() => _vm = new HooksViewModel(App);
}
