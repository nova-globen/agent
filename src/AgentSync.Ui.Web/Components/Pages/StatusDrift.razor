@page "/status"
@inject AgentSyncApp App

<PageTitle>Agent Sync — Status</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentLabel Typo="Typography.H3">Status / Drift</FluentLabel>

    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
        <FluentButton OnClick="@(() => _vm.Refresh())">Refresh</FluentButton>
    </FluentStack>

    @if (_vm.Status is not null)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                <FluentLabel>Initialized: @_vm.Status.Initialized — Skills: @_vm.Status.SkillCount</FluentLabel>
                <FluentLabel>Validation: @(_vm.Validation?.IsValid == true ? "valid" : "errors")</FluentLabel>

                @if (_vm.Status.Issues.Count == 0)
                {
                    <FluentLabel>No issues detected.</FluentLabel>
                }
                else
                {
                    @foreach (var issue in _vm.Status.Issues)
                    {
                        <FluentLabel>[@issue.Severity] @issue.Message</FluentLabel>
                    }
                }
            </FluentStack>
        </FluentCard>
    }

    @if (_vm.Drift is not null && _vm.Drift.HasDrift)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                <FluentLabel Typo="Typography.H4">Drift</FluentLabel>
                @foreach (var item in _vm.Drift.Drifted)
                {
                    <FluentLabel>[@item.Kind] <code>@item.RelativePath</code> (@item.TargetId)</FluentLabel>
                }
                @foreach (var orphan in _vm.Drift.Orphans)
                {
                    <FluentLabel>[Orphan] <code>@orphan.Path</code> (@orphan.Target)</FluentLabel>
                }
            </FluentStack>
        </FluentCard>
    }

    @* ---- Sync ---- *@
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
            <FluentLabel Typo="Typography.H4">Sync</FluentLabel>
            <FluentLabel Typo="Typography.Body">
                Run sync writes missing/outdated projections. Hand-edited generated sections are left
                untouched unless you confirm <strong>Force</strong>, which regenerates them from the
                canonical source.
            </FluentLabel>
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true">
                <FluentButton OnClick="@(() => _vm.RunSync(dryRun: true))">Preview (dry run)</FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _vm.RunSync(dryRun: false))">Run sync</FluentButton>
                <FluentButton OnClick="@(() => _vm.RequestForceSync())">Force sync…</FluentButton>
            </FluentStack>

            @if (_vm.ForceSyncPending)
            {
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                        <FluentLabel>Force overwrites manually edited generated projections. Continue?</FluentLabel>
                        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _vm.ConfirmForceSync())">Confirm force sync</FluentButton>
                            <FluentButton OnClick="@(() => _vm.CancelForceSync())">Cancel</FluentButton>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            }

            @if (_vm.Sync is not null)
            {
                <FluentCard Style="margin-top: 8px;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
                        <FluentLabel>
                            <strong>Sync:</strong> @(_vm.Sync.DryRun ? "dry run — " : "")@(_vm.Sync.ConfigValid ? "config valid" : "config invalid"),
                            @(_vm.Sync.AnyChanges ? "changes applied" : "no changes")@(_vm.Sync.AnySkippedManualEdits ? ", manual edits skipped" : "")
                        </FluentLabel>
                        @foreach (var outcome in _vm.Sync.Outcomes)
                        {
                            <FluentLabel><code>@outcome.Projection.RelativePath</code> (@outcome.Projection.TargetId) — @outcome.Change</FluentLabel>
                        }
                    </FluentStack>
                </FluentCard>
            }
        </FluentStack>
    </FluentCard>
</FluentStack>

@code {
    private StatusViewModel _vm = default!;

    // Repository logic lives in StatusViewModel / AgentSyncApp, never in this component.
    protected override void OnInitialized() => _vm = new StatusViewModel(App);
}
