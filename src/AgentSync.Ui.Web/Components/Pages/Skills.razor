@page "/skills"
@inject AgentSyncApp App

<PageTitle>Agent Sync — Skills</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentLabel Typo="Typography.H3">Skills</FluentLabel>

    @* ---- Add skill (explicit submit; writes a new canonical skill) ---- *@
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
            <FluentLabel Typo="Typography.H4">Add a skill</FluentLabel>
            <FluentTextField @bind-Value="_vm.AddId" Label="Id (kebab-case)" Placeholder="docs-review" />
            <FluentTextField @bind-Value="_vm.AddName" Label="Name" Placeholder="Docs Review" />
            <FluentTextField @bind-Value="_vm.AddDescription" Label="Description" />
            <FluentTextField @bind-Value="_vm.AddVersion" Label="Version (optional)" Placeholder="0.1.0" />
            <FluentLabel Typo="Typography.Body">New skills enable all known targets by default; tune them with Edit.</FluentLabel>
            <div>
                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _vm.Add())" Disabled="@string.IsNullOrWhiteSpace(_vm.AddId)">Add skill</FluentButton>
            </div>
            <AuthoringResultView Result="_vm.AddResult" />
        </FluentStack>
    </FluentCard>

    @* ---- Existing skills ---- *@
    @if (_vm.Skills.Count == 0)
    {
        <FluentLabel>No skills defined.</FluentLabel>
    }
    else
    {
        @foreach (var skill in _vm.Skills)
        {
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                    <FluentLabel><strong>@skill.Id</strong> — @skill.Manifest.Name</FluentLabel>
                    <FluentLabel>@skill.Manifest.Description</FluentLabel>
                    <FluentLabel>Version: @(string.IsNullOrWhiteSpace(skill.Manifest.Version) ? "—" : skill.Manifest.Version)</FluentLabel>
                    <FluentLabel>Targets: @string.Join(", ", skill.EnabledTargets)</FluentLabel>

                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                        <FluentButton OnClick="@(() => _vm.BeginEdit(skill))">Edit…</FluentButton>
                        <FluentButton OnClick="@(() => _vm.RequestDelete(skill.Id))">Delete…</FluentButton>
                    </FluentStack>

                    @* ---- Inline edit form (explicit Save) ---- *@
                    @if (_vm.EditId == skill.Id)
                    {
                        <FluentCard Style="margin-top: 8px;">
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                                <FluentLabel Typo="Typography.H4">Edit @skill.Id</FluentLabel>
                                <FluentTextField @bind-Value="_vm.EditName" Label="Name" />
                                <FluentTextField @bind-Value="_vm.EditDescription" Label="Description" />
                                <FluentTextField @bind-Value="_vm.EditVersion" Label="Version" />
                                <FluentTextArea @bind-Value="_vm.EditBodyFile" Label="Body file path (optional)" Placeholder="path/to/SKILL.md" />
                                <FluentLabel><strong>Enabled targets:</strong></FluentLabel>
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" Wrap="true">
                                    @foreach (var target in TargetIds.Ordered)
                                    {
                                        <FluentCheckbox @bind-Value="_vm.EditTargets[target]" Label="@target" />
                                    }
                                </FluentStack>
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                                    <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _vm.SaveEdit())">Save changes</FluentButton>
                                    <FluentButton OnClick="@(() => _vm.CancelEdit())">Cancel</FluentButton>
                                </FluentStack>
                                <AuthoringResultView Result="_vm.EditResult" />
                            </FluentStack>
                        </FluentCard>
                    }

                    @* ---- Inline delete confirmation (second step before any write) ---- *@
                    @if (_vm.PendingDeleteId == skill.Id)
                    {
                        <FluentCard Style="margin-top: 8px;">
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                                <FluentLabel Typo="Typography.H4">Delete @skill.Id?</FluentLabel>
                                <FluentLabel>
                                    This removes the canonical skill under <code>.agent/skills/@skill.Id</code>.
                                    Already-generated sections in shared files (AGENTS.md, CLAUDE.md, …) are left
                                    in place until you prune or re-sync. Use <strong>Force</strong> to delete a
                                    skill that has already been projected (also prunes its lockfile entries).
                                </FluentLabel>
                                <FluentCheckbox @bind-Value="_vm.DeleteDryRun" Label="Dry run (preview only — nothing written)" />
                                <FluentCheckbox @bind-Value="_vm.DeleteForce" Label="Force (delete even if projected; prune lockfile)" />
                                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                                    <FluentButton Appearance="Appearance.Accent" OnClick="@(() => _vm.ConfirmDelete())">Confirm delete</FluentButton>
                                    <FluentButton OnClick="@(() => _vm.CancelDelete())">Cancel</FluentButton>
                                </FluentStack>
                                <AuthoringResultView Result="_vm.DeleteResult" />
                            </FluentStack>
                        </FluentCard>
                    }
                </FluentStack>
            </FluentCard>
        }
    }
</FluentStack>

@code {
    private SkillsViewModel _vm = default!;

    // Repository logic lives in SkillsViewModel / AgentSyncApp, never in this component.
    protected override void OnInitialized() => _vm = new SkillsViewModel(App);
}
