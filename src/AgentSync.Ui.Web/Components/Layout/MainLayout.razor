@inherits LayoutComponentBase
@inject AgentSyncApp App

<div class="app-shell">
    <header class="app-header">
        <span class="app-brand">
            <span class="mark">&#x21BB;</span>
            Agent Sync
            <span class="sub">local web UI</span>
        </span>

        @{
            var (cls, dot, text) = StatusPill();
        }
        <span class="status-pill @cls" title="Repository status">
            <span class="dot"></span>@text
        </span>

        <span class="app-header-spacer"></span>
        <span class="app-repo" title="@App.RepoRoot">@App.RepoRoot</span>
    </header>

    <div class="app-body">
        <nav class="app-nav">
            <div class="nav-section">Manage</div>
            <NavMenu />
        </nav>
        <main class="app-content">
            <div class="content-inner">
                @Body
            </div>
        </main>
    </div>

    <footer class="app-footer">
        <span>Agent Sync</span>
        <span class="app-footer-spacer"></span>
        <span>Bound to <code>127.0.0.1</code> · session-token protected</span>
    </footer>
</div>

@code {
    // A single, repo-wide status read for the header pill. Guarded: a failure here must
    // never break the chrome that wraps every page.
    private (string Cls, string Dot, string Text) StatusPill()
    {
        try
        {
            var state = App.GetState();
            if (!state.Initialized)
            {
                return ("idle", "", "Not initialized");
            }
            return state.HasProblems
                ? ("warn", "", "Drift")
                : ("ok", "", "In sync");
        }
        catch
        {
            return ("idle", "", "Unknown");
        }
    }
}
