@* Skeleton dashboard component. Demonstrates the architecture rule: the component reads
   state through the injected AgentSyncApp application service and contains NO repository
   mutation logic of its own. Real screens (Skills, Imports, Targets, Drift, Diff,
   Hooks/CI, Settings, Logs) land in Milestone H. *@
@page "/"
@using AgentSync.Ui.Abstractions
@inject AgentSyncApp App

<h1>Agent Sync</h1>

<p>Repository: <code>@_state?.RepoPath</code></p>
<p>Initialized: @(_state?.Initialized == true ? "yes" : "no")</p>
<p>Skills: @(_state?.SkillCount)</p>

<p>CI command: <code>@AgentSyncApp.CiCommand</code></p>

@code {
    private RepositoryState? _state;

    protected override void OnInitialized()
    {
        // Read-only view of state; mutations happen only via confirmed actions that call
        // the application service, never inline in markup.
        _state = App.GetState();
    }
}
