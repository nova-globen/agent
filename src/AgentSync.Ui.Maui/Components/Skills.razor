@* Skeleton Skills screen. Lists skills and delegates every mutation to AgentSyncApp;
   destructive actions (delete) must be confirmed before calling the service. No
   repository logic lives here. Rendering is verified in a MAUI-workload build. *@
@page "/skills"
@using AgentSync.Core.Configuration
@using AgentSync.Ui.Abstractions
@inject AgentSyncApp App

<h1>Skills</h1>

@if (_skills is null)
{
    <p>Loading…</p>
}
else
{
    <ul>
        @foreach (var skill in _skills)
        {
            <li><strong>@skill.Id</strong> — @skill.Manifest.Name (@skill.EnabledTargets.Count() targets)</li>
        }
    </ul>
}

@code {
    private IReadOnlyList<Skill>? _skills;

    protected override void OnInitialized() => _skills = App.ListSkills();

    // Mutations call App.AddSkill / App.EditSkill / App.DeleteSkill after a confirmation
    // dialog; the component never touches the filesystem or lockfile directly.
}
