<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\AgentSync.Core\AgentSync.Core.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>agent</AssemblyName>
    <RootNamespace>AgentSync.Cli</RootNamespace>

    <!-- Publish as a .NET tool: `dotnet tool install Agent.Sync` exposes `agent`. -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>agent</ToolCommandName>
    <PackageId>Agent.Sync</PackageId>
    <IsPackable>true</IsPackable>
    <RollForward>Major</RollForward>
    <Description>Agent Sync — a Git-native consistency manager for AI-agent skills and instructions. Define a canonical skill once under .agent/ and project it into AGENTS.md, CLAUDE.md, Cursor rules, GitHub Copilot, Gemini, and OpenAI/Claude skill folders, with drift detection and Git-hook/CI enforcement. Installs the `agent` command (also usable as `git agent` with the Agent.Sync.Git package).</Description>
  </PropertyGroup>

</Project>
